<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Just a small town girl</title>
<meta name="robots" content="noindex">

<link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

<style>
body{
  margin:0;
  padding:0;
  font-family:'Poppins', sans-serif;
  background:#f2f2f2;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

#desk-container{
  position:relative;
  width:800px;
  height:500px;
  background:url('desk.png') no-repeat center/cover;
}

#laptop{
  position:absolute;
  bottom:120px;
  left:50%;
  transform:translateX(-50%) scale(1);
  width:300px;
  cursor:pointer;
  transition: transform 0.3s;
  z-index:2;
}

#laptop:hover{
  transform:translateX(-50%) scale(1.05);
}

#screen-text{
  position:absolute;
  bottom:220px; /* približno nad laptopom */
  left:50%;
  transform:translateX(-50%);
  font-size:24px;
  color:white;
  background:rgba(0,0,0,0.7);
  padding:10px 20px;
  border-radius:8px;
  opacity:0; /* skrito na začetku */
  transition: opacity 0.5s;
  z-index:3;
}

.laptop-opening{
  animation: openLaptop 1s forwards;
}

@keyframes openLaptop {
  0% { transform:translateX(-50%) scale(1) rotateX(0deg);}
  30% { transform:translateX(-50%) scale(1.05) rotateX(15deg);}
  60% { transform:translateX(-50%) scale(1.05) rotateX(45deg);}
  100% { transform:translateX(-50%) scale(1.05) rotateX(0deg);}
}
</style>
</head>

<body>

<div id="desk-container">
  <img id="laptop" src="laptop_closed.png" alt="Laptop">
  <div id="screen-text">Welcome to my page</div>
</div>

<script>
const laptop = document.getElementById('laptop');
const screenText = document.getElementById('screen-text');

laptop.addEventListener('click', ()=>{
  // animacija odpiranja laptopa
  laptop.classList.add('laptop-opening');
  
  // po 1s zamenjaj sliko na odprt laptop
  setTimeout(()=>{
    laptop.src = 'laptop_open.png';
    laptop.classList.remove('laptop-opening');
    
    // pokaži napis na zaslonu
    screenText.style.opacity = '1';
    
    // po 10s napis izgine
    setTimeout(()=>{
      screenText.style.opacity = '0';
    }, 10000); // 10000ms = 10s
  }, 1000); // dolžina animacije
});
</script>

</body>
</html>
